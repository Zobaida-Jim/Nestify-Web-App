<% layout("layouts/boilerplate") %>

    <div class="row mt-3">
        <h3 class="col-6 offset-3">SignUp on Nestify</h3>
        <div class="col-6 offset-3">
            <form action="/signup" method="post" novalidate class="needs-validation">
                <div class="mb-3">
                    <label class="form-label" for="username">Username </label>
                    <input name="username" type="text" class="form-control" required id="username">
                    <div class="invalid-feedback">Please enter username</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="email">Email </label>
                    <input name="email" type="email" class="form-control" required id="email">
                    <div class="invalid-feedback">Please enter email</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Password </label>
                    <input name="password" type="password" class="form-control" required id="password">
                    <div class="invalid-feedback">Please enter password</div>
                </div>

                <button class="btn btn-success">SignUp</button>
            </form>
        </div>
    </div>